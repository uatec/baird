<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Baird.ViewModels"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Baird.Controls.RequestsControl"
             x:CompileBindings="True"
             x:DataType="vm:RequestsViewModel">

    <Grid RowDefinitions="Auto,*" Background="Transparent">
        
        <!-- Row 0: Header -->
        <Border Grid.Row="0" Padding="20" KeyboardNavigation.IsTabStop="False">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" 
                               Text="Requests" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="White"
                               IsTabStop="False"/>
                    
                    <Button Grid.Column="1" 
                            Content="↻ Refresh"
                            Command="{Binding RefreshCommand}"
                            Background="#333333"
                            BorderBrush="#555555"
                            Padding="15,8"
                            CornerRadius="4"/>
                </Grid>
                
                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="14" 
                           Foreground="#AAAAAA"
                           TextWrapping="Wrap"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Requests Grid -->
        <ScrollViewer Grid.Row="1"
                      Focusable="False"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      KeyboardNavigation.TabNavigation="Contained">
            <ItemsControl Name="RequestsList" 
                          ItemsSource="{Binding Requests}"
                          Background="Transparent"
                          XYFocus.NavigationModes="Enabled">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="4"
                                CornerRadius="8"
                                Padding="10"
                                Command="{Binding $parent[UserControl].DataContext.PlayCompletedCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding IsAvailable}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                            <Button.Styles>
                                <Style Selector="Button:disabled">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Style>
                                <Style Selector="Button:focus">
                                    <Setter Property="BorderBrush" Value="#eeeeee"/>
                                </Style>
                            </Button.Styles>

                            <Grid RowDefinitions="*, Auto, Auto, Auto">
                                <!-- Poster Image -->
                                <Border Grid.Row="0"
                                        CornerRadius="8"
                                        ClipToBounds="True"
                                        Background="#333333"
                                        Height="169">
                                    <Panel>
                                        <Image asyncImage:ImageLoader.Source="{Binding FullPosterUrl}"
                                               Stretch="Uniform"/>

                                        <!-- Play Icon Overlay for Available Items -->
                                        <Border Background="#AA000000"
                                                CornerRadius="50"
                                                Width="40"
                                                Height="40"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding IsAvailable}">
                                            <TextBlock Text="▶"
                                                       FontSize="20"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="3,0,0,0"/>
                                        </Border>
                                    </Panel>
                                </Border>

                                <!-- Title -->
                                <TextBlock Grid.Row="1" Text="{Binding Title}"
                                           Foreground="White" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" TextAlignment="Left"
                                           Margin="0,5,0,0"/>

                                <!-- Badges Row -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                    <Border Background="#333333" CornerRadius="4" Padding="4,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding BadgeText}" Foreground="#4CC9F0" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="{Binding StatusColor}" CornerRadius="4" Padding="4,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <!-- Date and Progress -->
                                <StackPanel Grid.Row="3" Margin="0,2,0,0" Spacing="3">
                                    <TextBlock Text="{Binding FormattedDate}" FontSize="10" Foreground="#AAAAAA"/>
                                    <ProgressBar Height="4"
                                                 Minimum="0" Maximum="100"
                                                 Value="{Binding Progress}"
                                                 Foreground="{Binding StatusColor}"
                                                 Background="#333333"
                                                 BorderThickness="0"
                                                 CornerRadius="2"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Loading State -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    IsVisible="{Binding IsLoading}">
            <TextBlock Text="Loading requests..." 
                       FontSize="20" 
                       Foreground="#AAAAAA" 
                       HorizontalAlignment="Center"/>
            <ProgressBar IsIndeterminate="True" 
                         Width="200" 
                         Margin="0,10,0,0" 
                         Height="4"/>
        </StackPanel>
        
        <!-- Empty State -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    IsVisible="{Binding !IsLoading}"
                    Opacity="0.6">
            <TextBlock Text="No active or recent requests" 
                       FontSize="18" 
                       Foreground="#666666" 
                       HorizontalAlignment="Center"
                       IsVisible="{Binding !Requests.Count}"/>
        </StackPanel>
    </Grid>
</UserControl>
